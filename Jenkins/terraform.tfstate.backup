            "max_history": 0,
            "metadata": {
              "app_version": "2.541.3",
              "chart": "jenkins",
              "first_deployed": 1775448097,
              "last_deployed": 1775450007,
              "name": "jenkins",
              "namespace": "jenkins",
              "notes": "1. Get your 'admin' user password by running:\n  kubectl exec --namespace jenkins -it svc/jenkins -c jenkins -- /bin/cat /run/secrets/additional/chart-admin-password \u0026\u0026 echo\n2. Visit http://jenkins.local\n\n3. Login with the password from step 1 and the username: admin\n4. Configure security realm and authorization strategy\n5. Use Jenkins Configuration as Code by specifying configScripts in your values.yaml file, see documentation: http://jenkins.local/configuration-as-code and examples: https://github.com/jenkinsci/configuration-as-code-plugin/tree/master/demos\n\nFor more information on running Jenkins on Kubernetes, visit:\nhttps://cloud.google.com/solutions/jenkins-on-container-engine\n\nFor more information about Jenkins Configuration as Code, visit:\nhttps://jenkins.io/projects/jcasc/\n\n\nNOTE: Consider disabling `installPlugins` if your image already contains plugins.\n",
              "revision": 4,
              "values": "{\"controller\":{\"JCasC\":{\"configScripts\":{\"cloud\":\"jenkins:\\n  clouds:\\n    - kubernetes:\\n        name: \\\"kubernetes\\\"\\n        serverUrl: \\\"https://kubernetes.default.svc.cluster.local\\\"\\n        namespace: \\\"jenkins\\\"\\n        jenkinsUrl: \\\"http://jenkins.jenkins.svc.cluster.local:8080\\\"\\n        jenkinsTunnel: \\\"jenkins-agent.jenkins.svc.cluster.local:50000\\\"\\n        templates:\\n          - name: \\\"jenkins-agent\\\"\\n            label: \\\"jnlp\\\"\\n            containers:\\n              - name: \\\"jnlp\\\"\\n                image: \\\"docker.m.daocloud.io/jenkins/jnlp-slave:alpine\\\"\\n                privileged: false\\n                alwaysPullImage: false\\n\",\"credentials\":\"credentials:\\n  system:\\n    domainCredentials:\\n      - credentials:\\n          - usernamePassword:\\n              scope: GLOBAL\\n              id: \\\"aliyun-registry-creds\\\"\\n              username: \\\"${ALIYUN_REGISTRY_USER}\\\"\\n              password: \\\"${ALIYUN_REGISTRY_PASS}\\\"\\n              description: \\\"Alibaba Cloud Container Registry\\\"\\n          - usernamePassword:\\n              scope: GLOBAL\\n              id: \\\"github-creds\\\"\\n              username: \\\"${GITHUB_USER}\\\"\\n              password: \\\"${GITHUB_TOKEN}\\\"\\n              description: \\\"GitHub Credentials\\\"\\n\",\"jobs\":\"jobs:\\n  - script: |\\n      pipelineJob('Demo-Pipeline') {\\n        definition {\\n          cps {\\n            script('''\\n              pipeline {\\n                  agent {\\n                      kubernetes {\\n                          yaml \\\"\\\"\\\"\\n              apiVersion: v1\\n              kind: Pod\\n              metadata:\\n                labels:\\n                  app: jenkins-agent\\n              spec:\\n                containers:\\n                - name: jnlp\\n                  image: docker.m.daocloud.io/jenkins/inbound-agent:alpine\\n                  workingDir: /home/jenkins/agent\\n                - name: dind\\n                  image: docker.m.daocloud.io/library/docker:dind\\n                  imagePullPolicy: IfNotPresent\\n                  workingDir: /home/jenkins/agent\\n                  securityContext:\\n                    privileged: true\\n                  env:\\n                  - name: DOCKER_TLS_CERTDIR\\n                    value: \\\"\\\"\\n                  tty: true\\n                - name: nginx \\n                  image: docker.m.daocloud.io/library/nginx:alpine\\n                  imagePullPolicy: IfNotPresent\\n                  workingDir: /home/jenkins/agent\\n                  command: ['cat']\\n                  tty: true\\n                - name: docker\\n                  image: docker.m.daocloud.io/library/docker:latest\\n                  imagePullPolicy: IfNotPresent\\n                  workingDir: /home/jenkins/agent\\n                  command: ['cat']\\n                  tty: true\\n                  env:\\n                  - name: DOCKER_HOST\\n                    value: tcp://localhost:2375\\n                - name: trivy\\n                  image: docker.m.daocloud.io/aquasec/trivy:0.43.0\\n                  imagePullPolicy: IfNotPresent\\n                  workingDir: /home/jenkins/agent\\n                  command: ['cat']\\n                  tty: true\\n                - name: kubectl\\n                  image: bitnami/kubectl:latest\\n                  workingDir: /home/jenkins/agent\\n                  command: ['cat']\\n                  tty: true\\n              \\\"\\\"\\\"\\n                      }\\n                  }\\n              \\n                  environment {\\n                      REGISTRY_DOMAIN = \\\"crpi-v1qihtqp9ipem36a.cn-shanghai.personal.cr.aliyuncs.com\\\"\\n                      REGISTRY_REPO = \\\"crpi-v1qihtqp9ipem36a.cn-shanghai.personal.cr.aliyuncs.com/imbucket/bucket\\\"\\n                      IMAGE_NAME = \\\"demo-app\\\"\\n                      VERSION = \\\"v1.0.${BUILD_NUMBER}\\\"\\n                  }\\n              \\n                  stages {\\n                      stage('Checkout') {\\n                          steps {\\n                              git branch: 'main', credentialsId: 'github-creds', url: 'https://github.com/jasonsproject/Demo.git'\\n                          }\\n                      }\\n                      stage('Build Image') {\\n                          steps {\\n                              container('docker') {\\n                                  // Diagnostic logs to check workspace structure\\n                                  sh 'pwd'\\n                                  sh 'ls -R'\\n                                  // Wait for DinD to be ready\\n                                  sh 'while ! docker info \\u003e /dev/null 2\\u003e\\u00261; do echo \\\"waiting for dind...\\\"; sleep 2; done'\\n                                  // Using direct relative path context\\n                                  sh 'docker build -t $IMAGE_NAME:$VERSION ./app'\\n                                  sh 'docker tag $IMAGE_NAME:$VERSION $IMAGE_NAME:latest'\\n                              }\\n                          }\\n                      }\\n                      stage('Push Image') {\\n                          steps {\\n                              container('docker') {\\n                                  withCredentials([usernamePassword(\\n                                      credentialsId: 'aliyun-registry-creds',\\n                                      usernameVariable: 'REGISTRY_USER',\\n                                      passwordVariable: 'REGISTRY_PASS'\\n                                  )]) {\\n                                      sh 'echo $REGISTRY_PASS | docker login -u $REGISTRY_USER --password-stdin $REGISTRY_DOMAIN'\\n                                      sh 'docker tag $IMAGE_NAME:$VERSION $REGISTRY_REPO:$VERSION'\\n                                      sh 'docker push $REGISTRY_REPO:$VERSION'\\n                                  }\\n                              }\\n                          }\\n                      }\\n                      stage('Security Scan') {\\n                          steps {\\n                              container('trivy') {\\n                                  sh 'trivy image $IMAGE_NAME:$VERSION'\\n                              }\\n                          }\\n                      }\\n              \\n                      stage('Deploy to Green') {\\n                          steps {\\n                              container('kubectl') {\\n                                  // Update image to the newly built one\\n                                  sh 'sed -i \\\"s|image: .*|image: $REGISTRY_REPO:$VERSION|g\\\" $WORKSPACE/k8s/green-deployment.yaml'\\n                                  sh 'kubectl apply -f $WORKSPACE/k8s/green-deployment.yaml'\\n                                  echo \\\"Green environment deployed.\\\"\\n                              }\\n                          }\\n                      }\\n              \\n                      stage('Manual Approval') {\\n                          steps {\\n                              input message: \\\"Promote Green to Blue (Live)?\\\", ok: \\\"Promote\\\"\\n                          }\\n                      }\\n              \\n                      stage('Switch Traffic') {\\n                          steps {\\n                              container('kubectl') {\\n                                  // Switch service to point to green\\n                                  sh \\\"\\\"\\\"kubectl patch service demo-service -p '{\\\"spec\\\":{\\\"selector\\\":{\\\"version\\\":\\\"green\\\"}}}'\\\"\\\"\\\"\\n                                  echo \\\"Traffic switched to Green environment!\\\"\\n                              }\\n                          }\\n                      }\\n                  }\\n              }\\n            '''.stripIndent())\\n            sandbox()\\n          }\\n        }\\n      }\\n\",\"security\":\"jenkins:\\n  securityRealm:\\n    local:\\n      allowsSignup: false\\n      users:\\n        - id: \\\"admin\\\"\\n          password: \\\"${JENKINS_ADMIN_PASSWORD}\\\"\\n  authorizationStrategy:\\n    loggedInUsersCanDoAnything:\\n      allowAnonymousRead: false\\n\",\"welcome-message\":\"jenkins:\\n  systemMessage: \\\"DevOps Demo\\\"\\n\"},\"enabled\":true},\"containerEnv\":[{\"name\":\"JENKINS_ADMIN_PASSWORD\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"admin-password\",\"name\":\"jenkins-credentials\"}}},{\"name\":\"ALIYUN_REGISTRY_USER\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"aliyun-registry-user\",\"name\":\"jenkins-credentials\"}}},{\"name\":\"ALIYUN_REGISTRY_PASS\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"aliyun-registry-pass\",\"name\":\"jenkins-credentials\"}}},{\"name\":\"GITHUB_USER\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"github-user\",\"name\":\"jenkins-credentials\"}}},{\"name\":\"GITHUB_TOKEN\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"github-token\",\"name\":\"jenkins-credentials\"}}}],\"image\":{\"registry\":\"docker.m.daocloud.io\"},\"ingress\":{\"annotations\":{\"kubernetes.io/ingress.class\":\"nginx\"},\"apiVersion\":\"networking.k8s.io/v1\",\"enabled\":true,\"hostName\":\"jenkins.local\",\"ingressClassName\":\"nginx\",\"labels\":{},\"path\":\"/\"},\"installPlugins\":[\"kubernetes\",\"workflow-aggregator\",\"git\",\"configuration-as-code\",\"blueocean\",\"credentials-binding\",\"job-dsl\"],\"javaOpts\":\"-Djenkins.install.runSetupWizard=false -Dorg.jenkinsci.plugins.durabletask.BourneShellScript.LAUNCH_DIAGNOSTICS=true\",\"persistence\":{\"enabled\":true,\"size\":\"10Gi\",\"storageClass\":\"hostpath\"},\"runAsGroup\":0,\"runAsUser\":0,\"servicePort\":8080,\"serviceType\":\"LoadBalancer\",\"targetPort\":8080,\"updateCenter\":\"https://mirrors.tuna.tsinghua.edu.cn/jenkins/updates/update-center.json\"}}",
              "version": "5.9.12"
            },
            "name": "jenkins",
            "namespace": "jenkins",
            "pass_credentials": false,
            "postrender": null,
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://charts.jenkins.io",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "resources": null,
            "reuse_values": false,
            "set": null,
            "set_list": null,
            "set_sensitive": null,
            "set_wo": null,
            "set_wo_revision": null,
            "skip_crds": false,
            "status": "deployed",
            "take_ownership": false,
            "timeout": 300,
            "timeouts": null,
            "upgrade_install": false,
            "values": [
              "controller:\n  image:\n    registry: \"docker.m.daocloud.io\"\n  runAsUser: 0\n  runAsGroup: 0\n  javaOpts: \"-Djenkins.install.runSetupWizard=false -Dorg.jenkinsci.plugins.durabletask.BourneShellScript.LAUNCH_DIAGNOSTICS=true\"\n\n  # Mount sensitive credentials from Kubernetes Secret\n  containerEnv:\n    - name: JENKINS_ADMIN_PASSWORD\n      valueFrom:\n        secretKeyRef:\n          name: jenkins-credentials\n          key: admin-password\n    - name: ALIYUN_REGISTRY_USER\n      valueFrom:\n        secretKeyRef:\n          name: jenkins-credentials\n          key: aliyun-registry-user\n    - name: ALIYUN_REGISTRY_PASS\n      valueFrom:\n        secretKeyRef:\n          name: jenkins-credentials\n          key: aliyun-registry-pass\n    - name: GITHUB_USER\n      valueFrom:\n        secretKeyRef:\n          name: jenkins-credentials\n          key: github-user\n    - name: GITHUB_TOKEN\n      valueFrom:\n        secretKeyRef:\n          name: jenkins-credentials\n          key: github-token\n  installPlugins:\n    - kubernetes\n    - workflow-aggregator\n    - git\n    - configuration-as-code\n    - blueocean\n    - credentials-binding\n    - job-dsl\n\n  # Mainland China Mirror\n  updateCenter: \"https://mirrors.tuna.tsinghua.edu.cn/jenkins/updates/update-center.json\"\n\n  # JCasC Configuration\n  JCasC:\n    enabled: true\n    configScripts:\n      welcome-message: |\n        jenkins:\n          systemMessage: \"DevOps Demo\"\n      security: |\n        jenkins:\n          securityRealm:\n            local:\n              allowsSignup: false\n              users:\n                - id: \"admin\"\n                  password: \"${JENKINS_ADMIN_PASSWORD}\"\n          authorizationStrategy:\n            loggedInUsersCanDoAnything:\n              allowAnonymousRead: false\n\n      credentials: |\n        credentials:\n          system:\n            domainCredentials:\n              - credentials:\n                  - usernamePassword:\n                      scope: GLOBAL\n                      id: \"aliyun-registry-creds\"\n                      username: \"${ALIYUN_REGISTRY_USER}\"\n                      password: \"${ALIYUN_REGISTRY_PASS}\"\n                      description: \"Alibaba Cloud Container Registry\"\n                  - usernamePassword:\n                      scope: GLOBAL\n                      id: \"github-creds\"\n                      username: \"${GITHUB_USER}\"\n                      password: \"${GITHUB_TOKEN}\"\n                      description: \"GitHub Credentials\"\n\n      # 2. Automated Job creation (Job DSL)\n      # This will be injected via Terraform's 'set' in main.tf\n      jobs: |\n        jobs:\n          - script: |\n              pipelineJob('Demo-Pipeline') {\n                definition {\n                  cps {\n                    script('''\n                      pipeline {\n                          agent {\n                              kubernetes {\n                                  yaml \"\"\"\n                      apiVersion: v1\n                      kind: Pod\n                      metadata:\n                        labels:\n                          app: jenkins-agent\n                      spec:\n                        containers:\n                        - name: jnlp\n                          image: docker.m.daocloud.io/jenkins/inbound-agent:alpine\n                          workingDir: /home/jenkins/agent\n                        - name: dind\n                          image: docker.m.daocloud.io/library/docker:dind\n                          imagePullPolicy: IfNotPresent\n                          workingDir: /home/jenkins/agent\n                          securityContext:\n                            privileged: true\n                          env:\n                          - name: DOCKER_TLS_CERTDIR\n                            value: \"\"\n                          tty: true\n                        - name: nginx \n                          image: docker.m.daocloud.io/library/nginx:alpine\n                          imagePullPolicy: IfNotPresent\n                          workingDir: /home/jenkins/agent\n                          command: ['cat']\n                          tty: true\n                        - name: docker\n                          image: docker.m.daocloud.io/library/docker:latest\n                          imagePullPolicy: IfNotPresent\n                          workingDir: /home/jenkins/agent\n                          command: ['cat']\n                          tty: true\n                          env:\n                          - name: DOCKER_HOST\n                            value: tcp://localhost:2375\n                        - name: trivy\n                          image: docker.m.daocloud.io/aquasec/trivy:0.43.0\n                          imagePullPolicy: IfNotPresent\n                          workingDir: /home/jenkins/agent\n                          command: ['cat']\n                          tty: true\n                        - name: kubectl\n                          image: bitnami/kubectl:latest\n                          workingDir: /home/jenkins/agent\n                          command: ['cat']\n                          tty: true\n                      \"\"\"\n                              }\n                          }\n                      \n                          environment {\n                              REGISTRY_DOMAIN = \"crpi-v1qihtqp9ipem36a.cn-shanghai.personal.cr.aliyuncs.com\"\n                              REGISTRY_REPO = \"crpi-v1qihtqp9ipem36a.cn-shanghai.personal.cr.aliyuncs.com/imbucket/bucket\"\n                              IMAGE_NAME = \"demo-app\"\n                              VERSION = \"v1.0.${BUILD_NUMBER}\"\n                          }\n                      \n                          stages {\n                              stage('Checkout') {\n                                  steps {\n                                      git branch: 'main', credentialsId: 'github-creds', url: 'https://github.com/jasonsproject/Demo.git'\n                                  }\n                              }\n                              stage('Build Image') {\n                                  steps {\n                                      container('docker') {\n                                          // Diagnostic logs to check workspace structure\n                                          sh 'pwd'\n                                          sh 'ls -R'\n                                          // Wait for DinD to be ready\n                                          sh 'while ! docker info \u003e /dev/null 2\u003e\u00261; do echo \"waiting for dind...\"; sleep 2; done'\n                                          // Using direct relative path context\n                                          sh 'docker build -t $IMAGE_NAME:$VERSION ./app'\n                                          sh 'docker tag $IMAGE_NAME:$VERSION $IMAGE_NAME:latest'\n                                      }\n                                  }\n                              }\n                              stage('Push Image') {\n                                  steps {\n                                      container('docker') {\n                                          withCredentials([usernamePassword(\n                                              credentialsId: 'aliyun-registry-creds',\n                                              usernameVariable: 'REGISTRY_USER',\n                                              passwordVariable: 'REGISTRY_PASS'\n                                          )]) {\n                                              sh 'echo $REGISTRY_PASS | docker login -u $REGISTRY_USER --password-stdin $REGISTRY_DOMAIN'\n                                              sh 'docker tag $IMAGE_NAME:$VERSION $REGISTRY_REPO:$VERSION'\n                                              sh 'docker push $REGISTRY_REPO:$VERSION'\n                                          }\n                                      }\n                                  }\n                              }\n                              stage('Security Scan') {\n                                  steps {\n                                      container('trivy') {\n                                          sh 'trivy image $IMAGE_NAME:$VERSION'\n                                      }\n                                  }\n                              }\n                      \n                              stage('Deploy to Green') {\n                                  steps {\n                                      container('kubectl') {\n                                          // Update image to the newly built one\n                                          sh 'sed -i \"s|image: .*|image: $REGISTRY_REPO:$VERSION|g\" $WORKSPACE/k8s/green-deployment.yaml'\n                                          sh 'kubectl apply -f $WORKSPACE/k8s/green-deployment.yaml'\n                                          echo \"Green environment deployed.\"\n                                      }\n                                  }\n                              }\n                      \n                              stage('Manual Approval') {\n                                  steps {\n                                      input message: \"Promote Green to Blue (Live)?\", ok: \"Promote\"\n                                  }\n                              }\n                      \n                              stage('Switch Traffic') {\n                                  steps {\n                                      container('kubectl') {\n                                          // Switch service to point to green\n                                          sh \"\"\"kubectl patch service demo-service -p '{\"spec\":{\"selector\":{\"version\":\"green\"}}}'\"\"\"\n                                          echo \"Traffic switched to Green environment!\"\n                                      }\n                                  }\n                              }\n                          }\n                      }\n                    '''.stripIndent())\n                    sandbox()\n                  }\n                }\n              }\n\n      # 1. K8s Cloud Config\n      cloud: |\n        jenkins:\n          clouds:\n            - kubernetes:\n                name: \"kubernetes\"\n                serverUrl: \"https://kubernetes.default.svc.cluster.local\"\n                namespace: \"jenkins\"\n                jenkinsUrl: \"http://jenkins.jenkins.svc.cluster.local:8080\"\n                jenkinsTunnel: \"jenkins-agent.jenkins.svc.cluster.local:50000\"\n                templates:\n                  - name: \"jenkins-agent\"\n                    label: \"jnlp\"\n                    containers:\n                      - name: \"jnlp\"\n                        image: \"docker.m.daocloud.io/jenkins/jnlp-slave:alpine\"\n                        privileged: false\n                        alwaysPullImage: false\n\n  # Persistence for Docker Desktop\n  persistence:\n    enabled: true\n    storageClass: \"hostpath\" \n    size: \"10Gi\"\n\n  # Service Type LoadBalancer on port 8080\n  serviceType: LoadBalancer\n  servicePort: 8080\n  targetPort: 8080\n\n  # Ingress configuration\n  ingress:\n    enabled: true\n    apiVersion: \"networking.k8s.io/v1\"\n    labels: {}\n    annotations: \n      kubernetes.io/ingress.class: nginx\n    hostName: jenkins.local # Access via http://jenkins.local\n    path: /\n    ingressClassName: nginx\n"
            ],
            "verify": false,
            "version": "5.9.12",
            "wait": true,
            "wait_for_jobs": false
          },
